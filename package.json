{
  "name": "vsf-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "content:generate": "python3 scripts/generate_content.py",
    "media:manifest": "python3 scripts/generate_media_manifest.py",
    "media:upload": "node scripts/upload-media-to-r2.mjs",
    "ads:validate": "python3 -m ads.cli validate --config ads/examples/campaigns.sample.json",
    "ads:plan": "python3 -m ads.cli plan --config ads/examples/campaigns.sample.json",
    "ads:apply": "python3 -m ads.cli apply --config ads/examples/campaigns.sample.json --confirm-live",
    "ads:snapshot": "python3 -m ads.cli snapshot --customer-id 6920724799",
    "ads:cleanup-plan": "python3 -m ads.cli cleanup-plan --config ads/examples/adgrants.cleanup.sample.json",
    "ads:cleanup-apply": "python3 -m ads.cli cleanup-apply --config ads/examples/adgrants.cleanup.sample.json --confirm-live",
    "ads:test": "python3 -m unittest discover -s ads/tests -t ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.758.0",
    "@aws-sdk/lib-storage": "^3.758.0",
    "@vercel/analytics": "^1.5.0",
    "clsx": "^2.1.1",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "isomorphic-dompurify": "^3.7.1",
    "next": "^15.3.0",
    "next-intl": "^4.0.0",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.5",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2"
  }
}
