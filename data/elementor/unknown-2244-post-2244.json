                  "elements": [
                    {
                      "id": "a0a539e",
                      "elType": "widget",
                      "settings": {
                        "image": {
                          "url": "https://vetiversansfrontieres.org/wp-content/uploads/2022/11/IMG-20220529-WA0001-e1668634435717.jpg",
                          "id": 1812,
