            {
              "id": "e679e2e",
              "elType": "widget",
              "settings": {
                "title": "The challenges of planting Vetiver",
                "align": "center",
                "_margin": {
                  "unit": "px",
                  "top": "19",
                  "right": "19",
                  "bottom": "19",
                  "left": "19",
                  "isLinked": true
