            {
              "id": "0c2fcb8",
              "elType": "widget",
              "settings": {
                "editor": "<p>Vetiver System is a tool in the global fight against climate change. It is a unique technique that can be planted on a large scale and can quickly improve soil quality. Our organization supports planting trees, but we believe that planting sterile grasses like Vetiver is a more scalable and faster way to regreen large land areas.</p>",
                "align": "center",
                "text_color": "#FFFFFF",
                "typography_typography": "custom",
                "typography_font_size": {
                  "unit": "px",
                  "size": 25,
                  "sizes": []
                },
                "typography_font_weight": "400",
                "text_shadow_text_shadow_type": "yes",
                "text_shadow_text_shadow": {
                  "horizontal": 2,
                  "vertical": 0,
                  "blur": 6,
                  "color": "#000000"
                },
                "__globals__": {
