                  "elements": [
                    {
                      "id": "ebc7c58",
                      "elType": "widget",
                      "settings": {
                        "title": "From Pasture to Food Jungle Gardens",
                        "header_size": "h3",
                        "align": "center",
                        "_margin": {
                          "unit": "px",
                          "top": "11",
                          "right": "11",
                          "bottom": "11",
                          "left": "11",
                          "isLinked": true
                        }
                      },
                      "elements": [],
                      "widgetType": "heading"
                    },
                    {
                      "id": "82b8a25",
                      "elType": "widget",
                      "settings": {
                        "editor": "<p><span style=\"font-weight: 400;\">One of the standout initiatives of Verdenergia was the regeneration of pasture fields. The focus was on breathing new life into depleted landscapes by implementing sustainable methods of food production. This marked a departure from destructive practices like burning forests to create arable land. In this transformative process, Verdenergia incorporated Vetiver System, a key component that played a crucial role in soil conservation and erosion control. </span></p>",
                        "_margin": {
                          "unit": "px",
                          "top": "18",
                          "right": "18",
                          "bottom": "18",
                          "left": "18",
                          "isLinked": true
                        }
                      },
                      "elements": [],
                      "widgetType": "text-editor"
                    }
                  ],
                  "isInner": true
                }
              ],
              "isInner": true
            },
            {
              "id": "0080f7c",
              "elType": "section",
              "settings": {
                "structure": "20"
              },
              "elements": [
                {
                  "id": "6692de4",
                  "elType": "column",
                  "settings": {
                    "_column_size": 50,
                    "_inline_size": null,
                    "content_position": "center"
                  },
                  "elements": [
                    {
                      "id": "b87455b",
                      "elType": "widget",
                      "settings": {
                        "editor": "<p><span style=\"font-weight: 400;\"><strong>Vetiver</strong>, a versatile grass known for its soil-stabilizing and erosion-control properties, has been a constant companion in this journey. Used strategically throughout the projects, Vetiver has played a crucial role in preventing soil erosion while establishing new crops, stabilizing landscapes, and fostering the growth of diverse ecosystems. Walking through their fields, you can see the benefical impact of designing on contour lines. The fertility and depth of soil is overwhelming all around the farm. </span></p>",
                        "drop_cap": "yes"
                      },
                      "elements": [],
                      "widgetType": "text-editor"
